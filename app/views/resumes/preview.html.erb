<div class="resume-preview">

  <header class="preview-header">
    <h1>Pré-visualização do currículo</h1>
    <p>Revise as informações encontradas antes de confirmar a importação.</p>
  </header>

  <% data = @resume.parsed_data || {} %>

  <section class="preview-card">
    <h2>👤 Dados Pessoais</h2>

    <p><strong>Nome:</strong> <%= data["nome"].presence || "Não encontrado" %></p>
    <p><strong>E-mail:</strong> <%= data["email"].presence || "Não encontrado" %></p>
    <p><strong>Telefone:</strong> <%= data["phone"].presence || "Não encontrado" %></p>
    <p><strong>Cidade:</strong> <%= data["city"].presence || "Não encontrada" %></p>
  </section>

  <section class="preview-card">
    <h2>📝 Resumo Profissional</h2>
    <%= simple_format(data["summary"].presence || "Não encontrado") %>
  </section>

  <section class="preview-card">
    <h2>🎓 Formação Acadêmica</h2>

    <% if data["education"].present? %>
      <ul>
        <% Array(data["education"]).each do |education| %>
          <li><%= education %></li>
        <% end %>
      </ul>
    <% else %>
      <p>Nenhuma formação encontrada.</p>
    <% end %>

  </section>

  <section class="preview-card">
    <h2>💼 Experiência Profissional</h2>

    <% if data["experience"].present? %>
      <ul>
        <% Array(data["experience"]).each do |experience| %>
          <li><%= experience %></li>
        <% end %>
      </ul>
    <% else %>
      <p>Nenhuma experiência encontrada.</p>
    <% end %>

  </section>

  <section class="preview-card">
    <h2>🚀 Habilidades</h2>

    <% if data["skills"].present? %>

      <div class="skills">

        <% Array(data["skills"]).each do |skill| %>
          <span class="skill-badge"><%= skill %></span>
        <% end %>

      </div>

    <% else %>

      <p>Nenhuma habilidade encontrada.</p>

    <% end %>

  </section>

  <section class="preview-card">

    <h2>📄 Texto extraído do PDF</h2>

    <p class="preview-description">
      Abaixo está uma prévia do texto extraído automaticamente do currículo.
    </p>

    <% preview_text = truncate(@resume.raw_text, length: 500, separator: " ") %>

    <div class="resume-text">
      <%= preview_text %>
    </div>

    <% if @resume.raw_text.present? && @resume.raw_text.length > 500 %>

      <details class="resume-details">

        <summary class="show-text-button">
          📖 Mostrar texto completo
        </summary>

        <div class="resume-text full-text">
          <%= @resume.raw_text %>
        </div>

      </details>

    <% end %>

  </section>

</div>