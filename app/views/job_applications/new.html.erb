<div class="job-application-container">

  <% if notice.present? %>
    <div class="alert alert-success">
      <%= notice %>
    </div>
  <% end %>


  <div class="page-header">
    <h1>Candidatar-se à vaga</h1>
    <p>Anexe seu currículo e, se desejar, escreva uma carta de apresentação.</p>
  </div>

  <div class="job-card">

    <div class="job-header">
      <h2><%= @job.title %></h2>
      <span class="badge"><%= @job.contract_type %></span>
    </div>

    <div class="job-info-grid">

      <div class="info-item">
        <span class="label">🏢 Empresa</span>

      </div>

      <div class="info-item">
        <span class="label">📍 Local</span>
        <span class="value"><%= @job.location %></span>
      </div>

      <div class="info-item">
        <span class="label">💰 Salário</span>
        <span class="value">
          <%= number_to_currency(@job.salary,
                unit: "R$ ",
                separator: ",",
                delimiter: ".") %>
        </span>
      </div>

      <div class="info-item">
        <span class="label">📅 Publicada em</span>
        <span class="value">
          <%= @job.created_at.strftime("%d/%m/%Y") %>
        </span>
      </div>

    </div>

    <div class="job-description">
      <h3>Descrição da vaga</h3>
      <%= simple_format(@job.description) %>
    </div>

  </div>

  <div class="job-card">
    <div>
      <strong>Name: <%= current_user.candidate.name %></strong> 
    </div>
    <div>
      <strong>Email: <%= current_user.candidate.email %></strong> 
    </div>
    <div>
      <strong>Website: <%= current_user.candidate.email %></strong> 
    </div>
  </div>  
  

  <div class="application-form-card">
    <div class="form-header">
      <h2>Enviar candidatura</h2>
      <p>Complete as informações abaixo para concluir sua candidatura.</p>
    </div>

    <div class="form-body">
      <%= render "form" %>
    </div>
  </div>
</div>

<details class="resume-selector">
  <summary class="btn btn-secondary">
    Selecionar currículo
  </summary>

  <div class="resume-content">
    <%= render "resume_form", job: @job, resume: @resume %>
  </div>
</details>
