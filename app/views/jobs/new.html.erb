<h1>Nova Vaga</h1>

<%= form_with model: @job do |form| %>

  <div>
    <%= form.label :title, "Título" %><br>
    <%= form.text_field :title %>
  </div>

  <div>
    <%= form.label :company_id, "Empresa" %><br>
    <%= form.collection_select :company_id, Company.all, :id, :name %>
  </div>

  <div>
    <%= form.label :location, "Local" %><br>
    <%= form.text_field :location %>
  </div>

  <div>
    <%= form.label :salary, "Salário" %><br>
    <%= form.text_field :salary %>
  </div>

  <div>
    <%= form.label :employment_type, "Tipo de contratação" %><br>
    <%= form.select :employment_type,
      ["CLT", "PJ", "Estágio", "Freelancer", "Temporário"] %>
  </div>

  <div>
    <%= form.label :requirements, "Requisitos" %><br>
    <%= form.text_area :requirements %>
  </div>

  <div>
    <%= form.label :description, "Descrição" %><br>
    <%= form.text_area :description %>
  </div>

  <%= form.submit "Criar vaga" %>

<% end %>