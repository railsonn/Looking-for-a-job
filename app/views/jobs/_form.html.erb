<%= form_with(model: job) do |form| %>

  <% if job.errors.any? %>
    <div class="alert alert-danger">
      <h3>
        <%= pluralize(job.errors.count, "erro") %> impediram o salvamento desta vaga:
      </h3>

      <ul>
        <% job.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= form.label :title, "Título da vaga" %>
    <%= form.text_field :title,
        class: "form-control",
        placeholder: "Ex.: Desenvolvedor Ruby on Rails" %>
  </div>

  <div class="form-group">
    <%= form.label :description, "Descrição da vaga" %>
    <%= form.text_area :description,
        rows: 6,
        class: "form-control",
        placeholder: "Descreva as responsabilidades da vaga..." %>
  </div>

  <div class="form-group">
    <%= form.label :salary, "Salário (R$)" %>
    <%= form.number_field :salary,
        step: 0.01,
        class: "form-control",
        placeholder: "3500.00" %>
  </div>

  <div class="form-group">
    <%= form.label :location, "Localização" %>
    <%= form.text_field :location,
        class: "form-control",
        placeholder: "Ex.: Home Office ou São Paulo - SP" %>
  </div>

  <div class="form-group">
    <%= form.label :contract_type, "Tipo de contrato" %>
    <%= form.select :contract_type,
        [
          ["CLT", "CLT"],
          ["PJ", "PJ"],
          ["Estágio", "Estágio"],
          ["Temporário", "Temporário"],
          ["Freelancer", "Freelancer"]
        ],
        { prompt: "Selecione o tipo de contrato" },
        class: "form-control" %>
  </div>

  <div class="form-group">
    <%= form.label :company_id, "Empresa" %>
    <%= form.collection_select :company_id,
        Company.order(:name),
        :id,
        :name,
        { prompt: "Selecione uma empresa" },
        { class: "form-control" } %>
  </div>

  <div class="form-actions">
    <%= link_to "Cancelar", jobs_path, class: "btn btn-secondary" %>

    <%= form.submit(
      job.persisted? ? "Atualizar vaga" : "Cadastrar vaga",
      class: "btn btn-primary"
    ) %>
  </div>

<% end %>