<h1>Vagas Disponíveis</h1>

<% if @jobs.any? %>
  <div class="jobs-list">
    <% @jobs.each do |job| %>
      <div class="job-card">

        <h2><%= job.title %></h2>

        <p>
          <strong>Empresa:</strong>
          <%= job.company.name %>
        </p>

        <p>
          <strong>Local:</strong>
          <%= job.location %>
        </p>

        <p>
          <strong>Contrato:</strong>
          <%= job.contract_type %>
        </p>

        <p>
          <strong>Salário:</strong>
          <%= number_to_currency(job.salary, unit: "R$ ", separator: ",", delimiter: ".") %>
        </p>

        <p>
          <%= truncate(job.description, length: 180) %>
        </p>

        <%= link_to "Ver detalhes", job_path(job), class: "btn btn-primary" %>

      </div>
    <% end %>
  </div>
<% else %>
  <p>Nenhuma vaga disponível no momento.</p>
<% end %>